@{
    ViewData["Title"] = "Productos - FacturaFácil.net";
}

<section class="hero-section-small">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-9">
                <h1 class="display-4 fw-bold">Nuestros Productos</h1>
                <p class="lead">Soluciones diseñadas para cada etapa de tu negocio: desde facturación básica hasta control comercial completo.</p>
            </div>
        </div>
    </div>
</section>

<section class="products-detail-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4" id="sistema-basico">
                <div class="precio-card h-100">
                    <h3>Sistema Básico</h3>
                    <p class="text-muted mb-3">Facturación esencial para operación diaria.</p>
                    <ul>
                        <li>CFDI 4.0</li>
                        <li>Catálogo de clientes y productos</li>
                        <li>Complemento de pagos</li>
                        <li>Reportes de facturación y ventas</li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-4" id="sistema-half">
                <div class="precio-card h-100">
                    <h3>Sistema HALF</h3>
                    <p class="text-muted mb-3">Incluye cuentas por cobrar y seguimiento de saldos.</p>
                    <ul>
                        <li>Todo lo del sistema básico</li>
                        <li>Alta de proveedores</li>
                        <li>Captura de compras</li>
                        <li>Reporte de cuentas por cobrar</li>
                        <li>Estado de cuenta de clientes</li>
                        <li>Reporte de abonos y antigüedad de saldos</li>
                        <li>Documentos pendientes por cobrar</li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-4" id="sistema-full">
                <div class="precio-card h-100">
                    <h3>Sistema FULL</h3>
                    <p class="text-muted mb-3">Control comercial e inventarios para empresas en crecimiento.</p>
                    <ul>
                        <li>Todo lo del sistema HALF</li>
                        <li>Notas de venta y cotizaciones</li>
                        <li>Inventarios, traspasos y reportes</li>
                        <li>Consultas analíticas de operación</li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-4" id="nomina">
                <div class="precio-card h-100">
                    <h3>Nómina</h3>
                    <p class="text-muted mb-3">Emisión y control de recibos para cumplimiento fiscal.</p>
                    <ul>
                        <li>Administración de nómina</li>
                        <li>Control de recibos</li>
                        <li>Gestión por usuario y sucursal</li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-4" id="carta-porte">
                <div class="precio-card h-100">
                    <h3>Sistema Carta porte</h3>
                    <p class="text-muted mb-3">CFDI 4.0 + Carta Porte 3.3 para logística y transporte.</p>
                    <ul>
                        <li>Facturación y complemento de pago</li>
                        <li>Órdenes de embarque y cotizaciones</li>
                        <li>Catálogos de remitente, destinatario y transporte</li>
                        <li>Reportes operativos</li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-4" id="respaldos">
                <div class="precio-card h-100">
                    <h3>Respaldos</h3>
                    <p class="text-muted mb-3">Respaldo de XML y PDF para mantener tu operación segura.</p>
                    <ul>
                        <li>Planes desde 2 GB hasta 100 GB</li>
                        <li>Cobro anual</li>
                        <li>Protección de documentos fiscales</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
