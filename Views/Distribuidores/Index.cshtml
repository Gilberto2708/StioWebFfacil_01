@{
    ViewData["Title"] = "Distribuidores - FacturaFácil.net";
}

<section class="hero-section-small">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold"><i class="bi bi-people-fill me-3"></i>Conviértete en Distribuidor</h1>
                <p class="lead">Emprende tu propio negocio con la plataforma de FacturaFácil.net.</p>
            </div>
            <div class="col-lg-4 text-end d-none d-lg-block">
                <i class="bi bi-shop" style="font-size:8rem;opacity:0.2;"></i>
            </div>
        </div>
    </div>
</section>

<section class="distribuidores-section">
    <div class="container">

        <!-- Intro stats -->
        <div class="dist-stats-row">
            <div class="dist-stat">
                <i class="bi bi-percent"></i>
                <span class="dist-stat-num">40%</span>
                <span class="dist-stat-label">Margen máximo de utilidad</span>
            </div>
            <div class="dist-stat">
                <i class="bi bi-calendar-check"></i>
                <span class="dist-stat-num">+15</span>
                <span class="dist-stat-label">Años en el mercado</span>
            </div>
            <div class="dist-stat">
                <i class="bi bi-graph-up-arrow"></i>
                <span class="dist-stat-num">Residual</span>
                <span class="dist-stat-label">Ingresos recurrentes</span>
            </div>
            <div class="dist-stat">
                <i class="bi bi-award-fill"></i>
                <span class="dist-stat-num">Tu marca</span>
                <span class="dist-stat-label">Opción de marca propia</span>
            </div>
        </div>

        <!-- ¿Por qué ser distribuidor? -->
        <div class="precios-section-header mt-5">
            <div class="precios-section-icon">
                <i class="bi bi-star-fill"></i>
            </div>
            <div>
                <h2>¿Por qué ser Distribuidor de FacturaFácil.net?</h2>
                <p>Programa con márgenes atractivos, acompañamiento y crecimiento comercial.</p>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-4">
                <div class="dist-benefit-card">
                    <div class="dist-benefit-icon"><i class="bi bi-cash-coin"></i></div>
                    <h5>Márgenes atractivos</h5>
                    <p>Hasta un 40% de utilidad en nuestros productos según el nivel de distribuidor que alcances.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="dist-benefit-card">
                    <div class="dist-benefit-icon"><i class="bi bi-arrow-repeat"></i></div>
                    <h5>Ingresos residuales</h5>
                    <p>Genera beneficios económicos continuos a través de anualidades y renovaciones de tus clientes.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="dist-benefit-card">
                    <div class="dist-benefit-icon"><i class="bi bi-mortarboard-fill"></i></div>
                    <h5>Capacitación incluida</h5>
                    <p>Soporte, cursos y programas de capacitación para que domines el producto y cierres más ventas.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="dist-benefit-card">
                    <div class="dist-benefit-icon"><i class="bi bi-trophy-fill"></i></div>
                    <h5>Ventajas competitivas</h5>
                    <p>Programas con ventajas para atraer y retener clientes frente a la competencia.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="dist-benefit-card">
                    <div class="dist-benefit-icon"><i class="bi bi-badge-tm-fill"></i></div>
                    <h5>Tu propia marca</h5>
                    <p>Construye tu propia identidad comercial sobre nuestra plataforma tecnológica probada.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="dist-benefit-card">
                    <div class="dist-benefit-icon"><i class="bi bi-shop-window"></i></div>
                    <h5>Presencia comercial</h5>
                    <p>Forma parte de una red que ayuda a miles de personas y negocios en todo México.</p>
                </div>
            </div>
        </div>

        <!-- ¿Qué necesito? -->
        <div class="dist-requisitos-card">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <h3 class="mb-4"><i class="bi bi-patch-question-fill me-2"></i>¿Qué necesito para emprender con FacturaFácil.net?</h3>
                    <div class="dist-requisito-item">
                        <div class="dist-req-num">01</div>
                        <div>
                            <h6>Motivación y ambición</h6>
                            <p>Ganas de crecer y construir tu propio negocio.</p>
                        </div>
                    </div>
                    <div class="dist-requisito-item">
                        <div class="dist-req-num">02</div>
                        <div>
                            <h6>Registro ante el SAT</h6>
                            <p>Operar como persona física o moral con actividad comercial.</p>
                        </div>
                    </div>
                    <div class="dist-requisito-item">
                        <div class="dist-req-num">03</div>
                        <div>
                            <h6>Conocimientos básicos</h6>
                            <p>Familiaridad con sistemas contables o informáticos.</p>
                        </div>
                    </div>
                    <div class="mt-4">
                        <a asp-controller="Distribuidores" asp-action="Registro" class="btn btn-primary btn-lg rounded-pill px-4">
                            <i class="bi bi-person-plus-fill me-2"></i>Iniciar registro
                        </a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="dist-porq-card">
                        <h4 class="mb-4"><i class="bi bi-building me-2"></i>¿Por qué trabajar con FacturaFácil.net®?</h4>
                        <ul class="dist-porq-list">
                            <li><i class="bi bi-check-circle-fill"></i>Empresa mexicana con más de 15 años de experiencia.</li>
                            <li><i class="bi bi-check-circle-fill"></i>Desarrollamos nuestras propias plataformas.</li>
                            <li><i class="bi bi-check-circle-fill"></i>Aliados tecnológicos PAC certificados por el SAT.</li>
                            <li><i class="bi bi-check-circle-fill"></i>Opción de construir tu propia marca.</li>
                            <li><i class="bi bi-check-circle-fill"></i>Oportunidad de negocio para miles de personas.</li>
                            <li><i class="bi bi-check-circle-fill"></i>Nuestras soluciones ayudan a miles de negocios.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
