@{
    ViewData["Title"] = "Nosotros - FacturaFácil.net";
}

<section class="hero-section-small">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold"><i class="bi bi-building me-3"></i>Nosotros</h1>
                <p class="lead">Confiabilidad, empatía y dinamismo para impulsar tu negocio.</p>
            </div>
            <div class="col-lg-4 text-end d-none d-lg-block">
                <i class="bi bi-people-fill" style="font-size:8rem;opacity:0.2;"></i>
            </div>
        </div>
    </div>
</section>

<section class="nosotros-section">
    <div class="container">

        <!-- Valores principales -->
        <div class="home-section-header text-center mb-5">
            <span class="home-section-badge"><i class="bi bi-heart-fill me-2"></i>Nuestros valores</span>
            <h2>Lo que nos define</h2>
            <p>Más de 15 años construyendo relaciones de confianza con nuestros clientes.</p>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-3">
                <div class="nosotros-valor-card">
                    <div class="nosotros-valor-icon">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h5>Seguridad</h5>
                    <p>Mantenemos segura la información de tu negocio con las mejores prácticas y principios de protección de datos.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="nosotros-valor-card">
                    <div class="nosotros-valor-icon">
                        <i class="bi bi-emoji-smile-fill"></i>
                    </div>
                    <h5>Empatía</h5>
                    <p>Nuestro equipo es empático y cortés, siempre a la altura de la necesidad de cada cliente.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="nosotros-valor-card">
                    <div class="nosotros-valor-icon">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <h5>Dinamismo</h5>
                    <p>Somos fanáticos en brindar la mejor atención tomando como primicia el dinamismo y la destreza.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="nosotros-valor-card">
                    <div class="nosotros-valor-icon">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <h5>Innovación</h5>
                    <p>Nos enfocamos en brindar mejores soluciones con entusiasmo y energía para el crecimiento de tu negocio.</p>
                </div>
            </div>
        </div>

        <!-- Quiénes somos — texto completo con formato visual -->
        <div class="nosotros-about-card">
            <div class="row align-items-center g-5">
                <div class="col-lg-5">
                    <div class="nosotros-about-visual">
                        <div class="nosotros-about-badge">
                            <i class="bi bi-calendar-check"></i>
                            <span>Fundada hace más de <strong>15 años</strong></span>
                        </div>
                        <div class="nosotros-about-badge">
                            <i class="bi bi-code-slash"></i>
                            <span>Tecnología <strong>100% propia</strong></span>
                        </div>
                        <div class="nosotros-about-badge">
                            <i class="bi bi-patch-check-fill"></i>
                            <span>PAC <strong>certificado SAT</strong></span>
                        </div>
                        <div class="nosotros-about-badge">
                            <i class="bi bi-people-fill"></i>
                            <span>Miles de <strong>clientes activos</strong></span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-7">
                    <h3 class="nosotros-about-title">¿Quiénes somos?</h3>
                    <p>Facturafacil.Net se ocupa de mantener segura la información de tu negocio porque sabemos que es esencial para la confianza. Para ello nos basamos en las buenas prácticas y principios.</p>
                    <p>Nuestro equipo de trabajo es empático y cortés a la necesidad de nuestro cliente. Somos fanáticos en ayudar y brindar la mejor atención tomando como primicia el dinamismo y la destreza.</p>
                    <p>Nos enfocamos en nuestros objetivos con entusiasmo y energía para brindar a nuestros clientes cada vez mejores soluciones.</p>
                    <div class="mt-4">
                        <a asp-controller="Contacto" asp-action="Index" class="btn btn-primary rounded-pill px-4 me-2">
                            <i class="bi bi-envelope me-2"></i>Contáctanos
                        </a>
                        <a asp-controller="Distribuidores" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">
                            <i class="bi bi-people me-2"></i>Ser distribuidor
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
