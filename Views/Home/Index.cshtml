@{
    ViewData["Title"] = "FacturaFácil.net - Lo hacemos sencillo para ti";
}

<!-- ===== HERO ===== -->
<section class="home-hero">
    <div class="home-hero-bg"></div>
    <div class="container home-hero-content">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-7">
                <div class="home-hero-badge">
                    <i class="bi bi-patch-check-fill me-2"></i>+15 años de experiencia fiscal
                </div>
                <h1 class="home-hero-title">Factura más fácil,<br>crece más rápido.</h1>
                <p class="home-hero-subtitle">Sistemas de facturación electrónica para emprendedores, PYMES y empresas. Tecnología propia, soporte especializado y cumplimiento fiscal garantizado.</p>
                <div class="home-hero-cta">
                    <a asp-controller="Precios" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-4 me-3">
                        <i class="bi bi-tags-fill me-2"></i>Ver precios
                    </a>
                    <a asp-controller="Contacto" asp-action="Index" class="btn btn-outline-light btn-lg rounded-pill px-4">
                        <i class="bi bi-headset me-2"></i>Hablar con asesor
                    </a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-flex justify-content-center">
                <div class="home-hero-stats">
                    <div class="home-stat-card">
                        <i class="bi bi-building"></i>
                        <span class="home-stat-num">+15</span>
                        <span class="home-stat-label">Años de experiencia</span>
                    </div>
                    <div class="home-stat-card">
                        <i class="bi bi-people-fill"></i>
                        <span class="home-stat-num">Miles</span>
                        <span class="home-stat-label">de clientes activos</span>
                    </div>
                    <div class="home-stat-card">
                        <i class="bi bi-shield-check"></i>
                        <span class="home-stat-num">CFDI 4.0</span>
                        <span class="home-stat-label">100% certificado SAT</span>
                    </div>
                    <div class="home-stat-card">
                        <i class="bi bi-headset"></i>
                        <span class="home-stat-num">Soporte</span>
                        <span class="home-stat-label">especializado incluido</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="home-hero-wave">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z"/></svg>
    </div>
</section>

<!-- ===== PRODUCTOS ===== -->
<section class="home-products" id="productos">
    <div class="container">
        <div class="home-section-header text-center">
            <span class="home-section-badge"><i class="bi bi-grid-3x3-gap-fill me-2"></i>Nuestros productos</span>
            <h2>Elige el sistema que necesitas</h2>
            <p>Desde facturación básica hasta operación comercial completa con inventarios y carta porte.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="home-product-card">
                    <div class="home-product-icon">
                        <i class="bi bi-file-earmark-text"></i>
                    </div>
                    <div class="home-product-body">
                        <h4>Sistema Básico</h4>
                        <p>Facturación CFDI 4.0, catálogo de clientes, productos y reportes esenciales.</p>
                    </div>
                    <a asp-controller="Productos" asp-action="Index" asp-fragment="sistema-basico" class="home-product-link">
                        Ver detalles <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="home-product-card home-product-featured">
                    <div class="home-product-badge-top">Más popular</div>
                    <div class="home-product-icon">
                        <i class="bi bi-file-earmark-bar-graph"></i>
                    </div>
                    <div class="home-product-body">
                        <h4>Sistema HALF</h4>
                        <p>Facturación con cuentas por cobrar, alta de proveedores y captura de compras.</p>
                    </div>
                    <a asp-controller="Productos" asp-action="Index" asp-fragment="sistema-half" class="home-product-link">
                        Ver detalles <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="home-product-card">
                    <div class="home-product-icon">
                        <i class="bi bi-boxes"></i>
                    </div>
                    <div class="home-product-body">
                        <h4>Sistema FULL</h4>
                        <p>Operación comercial completa: inventarios, cotizaciones, notas de venta y más.</p>
                    </div>
                    <a asp-controller="Productos" asp-action="Index" asp-fragment="sistema-full" class="home-product-link">
                        Ver detalles <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="home-product-card">
                    <div class="home-product-icon">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="home-product-body">
                        <h4>Nómina</h4>
                        <p>Gestión y timbrado de recibos de nómina integrado al SAT.</p>
                    </div>
                    <a asp-controller="Productos" asp-action="Index" asp-fragment="nomina" class="home-product-link">
                        Ver detalles <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="home-product-card">
                    <div class="home-product-icon">
                        <i class="bi bi-truck"></i>
                    </div>
                    <div class="home-product-body">
                        <h4>Sistema Carta Porte</h4>
                        <p>CFDI 4.0 con Complemento Carta Porte 3.3 para empresas de logística y transporte.</p>
                    </div>
                    <a asp-controller="Productos" asp-action="Index" asp-fragment="carta-porte" class="home-product-link">
                        Ver detalles <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="home-product-card">
                    <div class="home-product-icon">
                        <i class="bi bi-cloud-arrow-up"></i>
                    </div>
                    <div class="home-product-body">
                        <h4>Respaldos</h4>
                        <p>Almacenamiento seguro de XML y PDF en la nube con planes anuales flexibles.</p>
                    </div>
                    <a asp-controller="Productos" asp-action="Index" asp-fragment="respaldos" class="home-product-link">
                        Ver detalles <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== POR QUÉ ELEGIRNOS ===== -->
<section class="home-why">
    <div class="container">
        <div class="home-section-header text-center">
            <span class="home-section-badge"><i class="bi bi-star-fill me-2"></i>¿Por qué elegirnos?</span>
            <h2>Tecnología propia, respaldo real</h2>
            <p>No somos revendedores. Desarrollamos nuestras propias plataformas.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="home-why-card">
                    <div class="home-why-icon"><i class="bi bi-code-slash"></i></div>
                    <h5>Tecnología propia</h5>
                    <p>Plataformas desarrolladas internamente para mayor control y evolución constante.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="home-why-card">
                    <div class="home-why-icon"><i class="bi bi-shield-fill-check"></i></div>
                    <h5>PAC certificado SAT</h5>
                    <p>Aliados tecnológicos de vanguardia para el timbrado de CFDI con validez oficial.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="home-why-card">
                    <div class="home-why-icon"><i class="bi bi-headset"></i></div>
                    <h5>Soporte especializado</h5>
                    <p>Equipo empático y capacitado que resuelve tus dudas fiscales y técnicas.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="home-why-card">
                    <div class="home-why-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <h5>Red de distribuidores</h5>
                    <p>Crece tu negocio con nuestra red y accede a márgenes atractivos de hasta 40%.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== CTA FINAL ===== -->
<section class="home-cta-final">
    <div class="container">
        <div class="home-cta-inner">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h2><i class="bi bi-rocket-takeoff me-3"></i>¿Listo para comenzar?</h2>
                    <p>Conoce los planes, costos de timbres y precios de respaldos. Agenda una demostración sin costo.</p>
                </div>
                <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                    <a asp-controller="Precios" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-4 me-2 mb-2">
                        <i class="bi bi-tags-fill me-2"></i>Ver precios
                    </a>
                    <a asp-controller="Distribuidores" asp-action="Index" class="btn btn-outline-light btn-lg rounded-pill px-4 mb-2">
                        <i class="bi bi-people me-2"></i>Distribuidores
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
